{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkwright.dev/schemas/v0/agent-profile.schema.json",
  "x-sparkwrightProtocolVersion": "0.2",
  "title": "Sparkwright Agent Profile",
  "description": "Reusable run template for an agent role. Defines role guidance, tool boundaries, policy, step limits, and budget; it does not own credentials, sessions, installed skills, cron state, logs, or workspace storage.",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["primary", "child", "all"]
    },
    "model": {},
    "prompt": { "type": "string" },
    "experimental": {
      "type": "object",
      "description": "Application-owned run-template fields. Prefer experimental.prompt for profile-specific role guidance used when spawning runs.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["primary", "child", "all"]
        },
        "model": {},
        "prompt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "allowedTools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "deniedTools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "policy": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capabilityRule"
      }
    },
    "maxSteps": {
      "type": "integer",
      "minimum": 1
    },
    "runBudget": {
      "type": "object",
      "properties": {
        "maxDurationMs": { "type": "integer", "minimum": 1 },
        "maxModelCalls": { "type": "integer", "minimum": 1 },
        "maxToolCalls": { "type": "integer", "minimum": 1 },
        "maxTokens": { "type": "integer", "minimum": 1 },
        "maxCostUsd": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "properties": {
        "acp": { "$ref": "#/$defs/acpDelegateMetadata" },
        "externalCommand": {
          "$ref": "#/$defs/externalCommandDelegateMetadata"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "workspaceAccess": {
      "type": "string",
      "enum": ["none", "read_write"],
      "description": "Whether an external delegate receives direct project workspace access. Omit or set none to run away from the project directory; set read_write only for explicitly trusted delegates."
    },
    "acpDelegateMetadata": {
      "type": "object",
      "required": ["transport", "command"],
      "properties": {
        "transport": { "const": "stdio" },
        "command": { "type": "string", "minLength": 1 },
        "args": { "type": "array", "items": { "type": "string" } },
        "cwd": {
          "type": "string",
          "description": "Requires workspaceAccess read_write."
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "envMode": { "type": "string", "enum": ["inherit", "explicit"] },
        "workspaceAccess": { "$ref": "#/$defs/workspaceAccess" },
        "timeoutMs": { "type": "number" }
      },
      "additionalProperties": false
    },
    "externalCommandDelegateMetadata": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "args": { "type": "array", "items": { "type": "string" } },
        "cwd": {
          "type": "string",
          "description": "Requires workspaceAccess read_write."
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "envMode": { "type": "string", "enum": ["inherit", "explicit"] },
        "workspaceAccess": { "$ref": "#/$defs/workspaceAccess" },
        "timeoutMs": { "type": "number" },
        "input": { "type": "string", "enum": ["argument", "stdin", "none"] },
        "maxOutputBytes": { "type": "number" },
        "maxStdoutBytes": { "type": "number" },
        "maxStderrBytes": { "type": "number" },
        "successExitCodes": {
          "type": "array",
          "items": { "type": "integer" }
        }
      },
      "additionalProperties": false
    },
    "capabilityRule": {
      "type": "object",
      "required": ["action", "effect"],
      "properties": {
        "action": { "type": "string" },
        "resource": { "type": "string" },
        "effect": {
          "type": "string",
          "enum": ["allow", "deny", "requires_approval"]
        },
        "reason": { "type": "string" },
        "metadata": { "type": "object" },
        "source": {
          "type": "string",
          "enum": ["parent_agent", "parent_run", "child_agent", "runtime"]
        }
      },
      "additionalProperties": false
    }
  }
}
