{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkwright.dev/schemas/v0/event.schema.json",
  "x-sparkwrightProtocolVersion": "0.2",
  "title": "Sparkwright Event",
  "type": "object",
  "required": [
    "id",
    "runId",
    "type",
    "timestamp",
    "sequence",
    "payload",
    "metadata"
  ],
  "properties": {
    "id": { "type": "string" },
    "runId": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "run.created",
        "run.started",
        "run.resumed",
        "run.waiting_credentials",
        "run.credentials_refreshed",
        "run.completed",
        "run.failed",
        "run.cancelled",
        "run.cancel_requested",
        "run.command.enqueued",
        "run.command.applied",
        "run.notification.injected",
        "run.notification.source_failed",
        "run.state_transition.rejected",
        "run.budget.checked",
        "plan.created",
        "plan.reviewed",
        "plan.step.started",
        "plan.step.completed",
        "plan.step.failed",
        "model.requested",
        "model.turn.started",
        "model.turn.completed",
        "model.completed",
        "model.retrying",
        "model.stream.started",
        "model.stream.chunk",
        "model.stream.text",
        "model.stream.completed",
        "model.stream.failed",
        "model.stream.timeout",
        "model.assistant_text",
        "context.assembled",
        "context.compaction_requested",
        "context.compaction.started",
        "context.compaction.completed",
        "context.compaction.failed",
        "capability.index.failed",
        "skill.indexed",
        "skill.failed",
        "skill.loaded",
        "mcp.server.prepared",
        "agent.profile.derived",
        "prompt.built",
        "validation.started",
        "validation.completed",
        "validation.failed",
        "tool.requested",
        "tool.batch.requested",
        "tool.batch.completed",
        "tool.started",
        "tool.progress",
        "tool.completed",
        "tool.failed",
        "tool.replay_risk",
        "storage.degraded",
        "storage.recovered",
        "approval.requested",
        "approval.resolved",
        "artifact.created",
        "workspace.read",
        "workspace.read.denied",
        "workspace.anchored_read",
        "workspace.anchored_edit.requested",
        "workspace.anchored_edit.verified",
        "workspace.anchored_edit.rejected",
        "workspace.write.requested",
        "workspace.write.denied",
        "workspace.write.completed",
        "workspace.write.skipped",
        "usage.updated",
        "hook.failed",
        "workflow_hook.started",
        "workflow_hook.completed",
        "workflow_hook.blocked",
        "workflow_hook.failed",
        "interaction.requested",
        "interaction.resolved",
        "context.cache_break.detected",
        "subagent.requested",
        "subagent.started",
        "subagent.completed",
        "subagent.failed",
        "task.created",
        "task.started",
        "task.output",
        "task.completed",
        "task.failed",
        "task.cancelled",
        "user_hook.invoked",
        "user_hook.progress",
        "user_hook.completed",
        "user_hook.failed"
      ]
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "monotonicUs": {
      "type": "integer",
      "minimum": 0,
      "description": "Optional. Process-monotonic microseconds (from performance.now()) for sub-millisecond ordering and span durations. Shares one origin across all EventLogs in the process; NOT wall-clock. Absent on pre-v0.2 emitters — sinks fall back to timestamp. Added by ADR-0008."
    },
    "sequence": { "type": "integer", "minimum": 1 },
    "payload": {},
    "metadata": { "type": "object" },
    "traceId": {
      "type": "string",
      "description": "Optional. Correlates events across a single run-level trace tree. Defaults to runId when synthesized by a sink. Added by ADR-0008."
    },
    "spanId": {
      "type": "string",
      "description": "Optional. Stable id for the bracketed work this event belongs to. Paired *.started / *.completed events share the same spanId; instant events carry the enclosing span's id. Added by ADR-0008."
    },
    "parentSpanId": {
      "type": "string",
      "description": "Optional. Parent span in the trace tree. Set from AsyncLocalStorage at emit time when using withSpan(). Added by ADR-0008."
    }
  },
  "additionalProperties": false
}
