{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkwright.dev/schemas/v0/context-item.schema.json",
  "x-sparkwrightProtocolVersion": "0.2",
  "title": "Sparkwright Context Item",
  "type": "object",
  "required": ["id", "type", "content", "metadata"],
  "properties": {
    "id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["user", "system", "file", "tool_result", "summary"]
    },
    "source": {
      "type": "object",
      "properties": {
        "kind": { "type": "string" },
        "path": { "type": "string" },
        "uri": { "type": "string" }
      },
      "additionalProperties": false
    },
    "content": { "type": "string" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
