{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkwright.dev/schemas/v0/context-item.schema.json",
  "x-sparkwrightProtocolVersion": "0.2",
  "title": "Sparkwright Context Item",
  "type": "object",
  "required": ["id", "type", "content", "metadata"],
  "properties": {
    "id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["user", "system", "file", "tool_result", "summary"]
    },
    "source": {
      "type": "object",
      "properties": {
        "kind": { "type": "string" },
        "path": { "type": "string" },
        "uri": { "type": "string" }
      },
      "additionalProperties": false
    },
    "content": { "type": "string" },
    "parts": {
      "type": "array",
      "items": { "$ref": "#/$defs/ContentPart" }
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false,
  "$defs": {
    "ContentPart": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "text"],
          "properties": {
            "type": { "const": "text" },
            "text": { "type": "string" },
            "metadata": { "type": "object" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "type": "string", "enum": ["image", "file", "audio"] },
            "data": { "type": "string", "minLength": 1 },
            "uri": { "type": "string", "minLength": 1 },
            "mediaType": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "metadata": { "type": "object" }
          },
          "anyOf": [
            {
              "properties": { "data": { "type": "string", "minLength": 1 } },
              "required": ["data"]
            },
            {
              "properties": { "uri": { "type": "string", "minLength": 1 } },
              "required": ["uri"]
            }
          ],
          "additionalProperties": false
        }
      ]
    }
  }
}
