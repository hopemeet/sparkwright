{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkwright.dev/schemas/v0/anchored-text.schema.json",
  "x-sparkwrightProtocolVersion": "0.2",
  "title": "Sparkwright Anchored Text",
  "type": "object",
  "required": [
    "path",
    "anchorSetId",
    "lineCount",
    "content",
    "lines",
    "metadata"
  ],
  "properties": {
    "path": { "type": "string" },
    "anchorSetId": { "type": "string" },
    "lineCount": { "type": "integer", "minimum": 0 },
    "content": { "type": "string" },
    "lines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["line", "anchor", "hash", "content"],
        "properties": {
          "line": { "type": "integer", "minimum": 1 },
          "anchor": { "type": "string" },
          "hash": { "type": "string" },
          "content": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
