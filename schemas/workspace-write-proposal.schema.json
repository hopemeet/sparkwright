{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkwright.dev/schemas/v0/workspace-write-proposal.schema.json",
  "x-sparkwrightProtocolVersion": "0.2",
  "title": "Sparkwright Workspace Write Proposal",
  "type": "object",
  "required": [
    "id",
    "runId",
    "path",
    "content",
    "diff",
    "createdAt",
    "metadata"
  ],
  "properties": {
    "id": { "type": "string" },
    "runId": { "type": "string" },
    "path": { "type": "string" },
    "content": { "type": "string" },
    "diff": { "type": "string" },
    "reason": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
