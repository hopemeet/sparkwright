{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkwright.dev/schemas/v0/config.schema.json",
  "x-sparkwrightProtocolVersion": "0.2",
  "title": "Sparkwright Config",
  "description": "User-editable settings shared by the CLI and the interactive TUI. Loaded (in order, later overriding earlier) from ~/.config/sparkwright/config.{json,yaml,yml}, <workspace>/.sparkwright/config.{json,yaml,yml}, and $SPARKWRIGHT_CONFIG. Within a user/project layer, config.json wins over config.yaml, which wins over config.yml; multiple files in one layer are reported as a conflict. CLI args and env vars override files. Fields may be written flat or under the preferred groups identity/policy/run/ui; tools and capabilities are top-level groups. A field set both ways conflicts and the grouped value wins. The providers map is merged by key, tools.use and tools.allowed intersect, tools.disabled unions, tools.defer is replaced by later layers, capabilities merges by sub-capability, and the security boundaries - shell.sandbox, permissionMode, confidentialPaths, and write - merge conservatively so later layers cannot weaken an earlier layer's policy; other shared fields are wholesale-overridden.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional reference to this JSON Schema so editors can offer completion and validation. Ignored by the loader."
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^/]+(\\/.+)?$",
      "description": "Active model in the form \"provider/model\"."
    },
    "providers": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "npm": {
            "type": "string",
            "minLength": 1,
            "description": "AI SDK package used to construct the client. Defaults to \"@ai-sdk/openai\"."
          },
          "baseURL": {
            "type": "string",
            "format": "uri",
            "description": "OpenAI-compatible base URL. Overridden by the OPENAI_BASE_URL env var when set."
          },
          "apiKey": {
            "type": "string",
            "minLength": 1,
            "description": "API key for this provider. Overridden by provider-specific env vars when set."
          },
          "providerOptions": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "object",
              "properties": {},
              "additionalProperties": {}
            },
            "description": "Request-level AI SDK providerOptions keyed by provider namespace."
          },
          "models": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "object",
              "properties": {
                "cost": {
                  "type": "object",
                  "properties": {
                    "input": {
                      "type": "number"
                    },
                    "output": {
                      "type": "number"
                    },
                    "cacheRead": {
                      "type": "number"
                    },
                    "cacheWrite": {
                      "type": "number"
                    }
                  },
                  "additionalProperties": false,
                  "description": "Per-million-token pricing used to attach costUsd to usage."
                },
                "providerOptions": {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {
                    "type": "object",
                    "properties": {},
                    "additionalProperties": {}
                  },
                  "description": "Request-level AI SDK providerOptions keyed by provider namespace."
                }
              },
              "additionalProperties": false
            },
            "description": "Optional per-model metadata. When any models are listed, model overrides must use one of those ids."
          }
        },
        "additionalProperties": false
      },
      "description": "Named model providers. The reserved name \"deterministic\" is built in and must not be declared here."
    },
    "permissionMode": {
      "type": "string",
      "enum": [
        "plan",
        "default",
        "accept_edits",
        "dont_ask",
        "bypass_permissions"
      ],
      "description": "Permission policy mode for runs started from the TUI."
    },
    "workspace": {
      "type": "string",
      "minLength": 1,
      "description": "Workspace root for runs. Relative paths resolve from the directory of the config file that defined them."
    },
    "confidentialPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Opt-in read-confidentiality paths or globs whose contents a run must not read."
    },
    "write": {
      "type": "object",
      "properties": {
        "maxFiles": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991,
          "description": "Maximum distinct files a run may write."
        },
        "maxDiffLines": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991,
          "description": "Maximum changed diff lines per write."
        },
        "allowDeletions": {
          "type": "boolean",
          "description": "Whether in-place edits may remove lines."
        }
      },
      "additionalProperties": false,
      "description": "Workspace write guardrails. Merges conservatively across layers."
    },
    "runBudget": {
      "type": "object",
      "properties": {
        "maxDurationMs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "maxModelCalls": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "maxToolCalls": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "maxTokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "maxCostUsd": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false,
      "description": "Resource budget for the interactive main run. maxModelCalls is the tightest natural step bound."
    },
    "maxSteps": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991,
      "description": "Explicit main-run step ceiling."
    },
    "traceLevel": {
      "type": "string",
      "enum": ["standard", "debug"],
      "description": "Default trace verbosity when an entrypoint does not pass one. CLI --trace-level overrides."
    },
    "approvals": {
      "type": "object",
      "properties": {
        "shellSafe": {
          "type": "boolean",
          "description": "Auto-approve commands the safety classifier rates safe."
        },
        "edits": {
          "type": "boolean",
          "description": "Auto-approve workspace edits."
        },
        "all": {
          "type": "boolean",
          "description": "Auto-approve everything the policy allows."
        },
        "cronMode": {
          "type": "string",
          "enum": [
            "plan",
            "default",
            "accept_edits",
            "dont_ask",
            "bypass_permissions"
          ],
          "description": "Default permission mode for unattended cron run/tick commands. CLI --permission-mode still overrides."
        }
      },
      "additionalProperties": false,
      "description": "Default approval auto-grants. CLI flags still override these values."
    },
    "shell": {
      "type": "object",
      "properties": {
        "sandbox": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["off", "warn", "enforce"],
              "description": "off disables OS sandboxing; warn uses it when available; enforce fails shell execution when sandboxing is unavailable."
            },
            "failIfUnavailable": {
              "type": "boolean",
              "description": "Fail closed when the platform sandbox runtime is unavailable."
            },
            "filesystem": {
              "type": "object",
              "properties": {
                "allowRead": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "allowWrite": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "denyRead": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "denyWrite": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "tmp": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "network": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["allow", "deny"]
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false,
          "description": "OS-level process sandbox for local command execution. Forced deny-write paths are always appended by the host."
        }
      },
      "additionalProperties": false,
      "description": "Host shell execution boundary."
    },
    "tools": {
      "type": "object",
      "properties": {
        "use": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "workspace.read",
                  "workspace.write",
                  "shell",
                  "planning",
                  "skills",
                  "agents",
                  "tasks",
                  "cron",
                  "mcp"
                ]
              },
              {
                "type": "string",
                "pattern": "^mcp:.+$",
                "description": "Select tools from one configured MCP server, e.g. mcp:demo."
              }
            ]
          },
          "description": "High-level source/capability selectors retained in the prepared tool set. Omit to use all otherwise enabled tools."
        },
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Concrete tool names retained in the prepared run tool set. Omit to allow all otherwise enabled tools."
        },
        "disabled": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Concrete tool names removed from the prepared run tool set."
        },
        "defer": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Concrete built-in tool names prepared as deferred schemas when supported."
        }
      },
      "additionalProperties": false,
      "description": "Preferred tool exposure/loading settings. Standard tools are enabled by default."
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "hooks": {
          "type": "object",
          "properties": {
            "workflow": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "description": {
                    "type": "string"
                  },
                  "hook": {
                    "type": "string",
                    "enum": [
                      "SessionStart",
                      "UserPromptSubmit",
                      "ModelOutput",
                      "PreToolUse",
                      "PostToolUse",
                      "Stop",
                      "SessionEnd",
                      "RuntimeSignal"
                    ]
                  },
                  "enabled": {
                    "type": "boolean"
                  },
                  "onError": {
                    "type": "string",
                    "enum": ["continue", "block"]
                  },
                  "frequency": {
                    "type": "string",
                    "enum": ["always", "oncePerTurn"]
                  },
                  "matcher": {
                    "type": "object",
                    "properties": {
                      "toolName": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        ]
                      },
                      "eventType": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        ]
                      },
                      "signal": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        ]
                      },
                      "status": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        ]
                      },
                      "pathGlob": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        ]
                      },
                      "excludePathGlob": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        ]
                      }
                    },
                    "additionalProperties": false
                  },
                  "action": {
                    "anyOf": [
                      {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "const": "block"
                          },
                          "reason": {
                            "type": "string",
                            "minLength": 1
                          }
                        },
                        "required": ["type", "reason"],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "const": "context"
                          },
                          "content": {
                            "type": "string",
                            "minLength": 1
                          },
                          "contextType": {
                            "type": "string",
                            "enum": ["system", "user", "summary"]
                          }
                        },
                        "required": ["type", "content"],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "const": "command"
                          },
                          "command": {
                            "type": "string",
                            "minLength": 1
                          },
                          "args": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "cwd": {
                            "type": "string",
                            "minLength": 1
                          },
                          "timeoutMs": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 9007199254740991
                          },
                          "blockOnFailure": {
                            "type": "boolean"
                          },
                          "injectOutput": {
                            "type": "string",
                            "enum": ["always", "onFailure", "never"]
                          },
                          "maxOutputBytes": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 9007199254740991
                          },
                          "stdin": {
                            "type": "string",
                            "enum": ["none", "json"]
                          }
                        },
                        "required": ["type", "command"],
                        "additionalProperties": false
                      }
                    ]
                  }
                },
                "required": ["name", "hook", "action"],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false,
          "description": "Deterministic workflow hooks for host-created runs."
        },
        "verification": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["off", "suggest", "require"]
            },
            "defaultProfile": {
              "type": "string",
              "minLength": 1
            },
            "profiles": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "kind": {
                      "type": "string",
                      "enum": ["lint", "typecheck", "test", "check", "custom"]
                    },
                    "command": {
                      "type": "string",
                      "minLength": 1
                    },
                    "args": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "cwd": {
                      "type": "string",
                      "minLength": 1
                    },
                    "timeoutMs": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 9007199254740991
                    },
                    "maxOutputBytes": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": ["id", "command"],
                  "additionalProperties": false
                }
              }
            },
            "afterWrites": {
              "type": "object",
              "properties": {
                "profile": {
                  "type": "string",
                  "minLength": 1
                },
                "frequency": {
                  "type": "string",
                  "enum": ["always", "oncePerTurn"]
                },
                "injectOutput": {
                  "type": "string",
                  "enum": ["always", "onFailure", "never"]
                }
              },
              "additionalProperties": false
            },
            "stopGate": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "requireCleanAfterLastWrite": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false,
          "description": "Project verification profiles compiled by the host into workflow hooks."
        },
        "skills": {
          "type": "object",
          "properties": {
            "roots": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Skill root directories. Relative paths resolve from the config file that defined them."
            },
            "includeLoaderTool": {
              "type": "boolean",
              "description": "Register the progressive skill_load tool."
            },
            "loadSelectedSkills": {
              "type": "boolean",
              "description": "Load matcher-selected Skill bodies into resident context."
            },
            "maxSelectedSkills": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "resourceFileLimit": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "allowedSkills": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "deniedSkills": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "evolution": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["off", "notice", "draft", "apply"]
                }
              },
              "additionalProperties": false
            },
            "inlineShell": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "timeoutMs": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 9007199254740991
                },
                "maxOutputChars": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 9007199254740991
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false,
          "description": "Skill loading settings for host-created runs."
        },
        "mcp": {
          "type": "object",
          "properties": {
            "servers": {
              "type": "array",
              "items": {
                "$ref": "mcp-server-config.schema.json"
              }
            },
            "defaultTimeoutMs": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "namePrefix": {
              "type": "string"
            },
            "startup": {
              "type": "string",
              "enum": ["lazy", "prepare", "eager"]
            },
            "toolSchemaLoad": {
              "type": "string",
              "enum": ["eager", "defer"]
            },
            "defaultPolicy": {
              "type": "object",
              "properties": {
                "risk": {
                  "type": "string",
                  "enum": ["safe", "risky", "denied"]
                },
                "requiresApproval": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false,
          "description": "MCP server settings for host-created runs."
        },
        "agents": {
          "type": "object",
          "properties": {
            "profiles": {
              "type": "array",
              "items": {
                "$ref": "agent-profile.schema.json"
              }
            },
            "delegateTools": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "profileId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "toolName": {
                    "type": "string",
                    "minLength": 1
                  },
                  "description": {
                    "type": "string",
                    "minLength": 1
                  },
                  "requiresApproval": {
                    "type": "boolean"
                  },
                  "forbidNesting": {
                    "type": "boolean"
                  },
                  "maxSteps": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 9007199254740991
                  }
                },
                "required": ["profileId"],
                "additionalProperties": false
              }
            },
            "maxDepth": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991,
              "description": "Global sub-agent depth ceiling. 0 disables sub-agent spawning."
            }
          },
          "additionalProperties": false,
          "description": "Agent profile run templates for host-created runs."
        }
      },
      "additionalProperties": false,
      "description": "Host-owned capability runtime settings."
    },
    "theme": {
      "type": "string",
      "enum": ["dark", "light", "mono"],
      "description": "Visual theme."
    },
    "mouse": {
      "type": "boolean",
      "description": "Enable mouse reporting."
    },
    "keybindings": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "type": "null"
          }
        ]
      },
      "description": "Override default key chords for named TUI actions."
    },
    "identity": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^/]+(\\/.+)?$",
          "description": "Active model in the form \"provider/model\"."
        },
        "providers": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "npm": {
                "type": "string",
                "minLength": 1,
                "description": "AI SDK package used to construct the client. Defaults to \"@ai-sdk/openai\"."
              },
              "baseURL": {
                "type": "string",
                "format": "uri",
                "description": "OpenAI-compatible base URL. Overridden by the OPENAI_BASE_URL env var when set."
              },
              "apiKey": {
                "type": "string",
                "minLength": 1,
                "description": "API key for this provider. Overridden by provider-specific env vars when set."
              },
              "providerOptions": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": {}
                },
                "description": "Request-level AI SDK providerOptions keyed by provider namespace."
              },
              "models": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "cost": {
                      "type": "object",
                      "properties": {
                        "input": {
                          "type": "number"
                        },
                        "output": {
                          "type": "number"
                        },
                        "cacheRead": {
                          "type": "number"
                        },
                        "cacheWrite": {
                          "type": "number"
                        }
                      },
                      "additionalProperties": false,
                      "description": "Per-million-token pricing used to attach costUsd to usage."
                    },
                    "providerOptions": {
                      "type": "object",
                      "propertyNames": {
                        "type": "string"
                      },
                      "additionalProperties": {
                        "type": "object",
                        "properties": {},
                        "additionalProperties": {}
                      },
                      "description": "Request-level AI SDK providerOptions keyed by provider namespace."
                    }
                  },
                  "additionalProperties": false
                },
                "description": "Optional per-model metadata. When any models are listed, model overrides must use one of those ids."
              }
            },
            "additionalProperties": false
          },
          "description": "Named model providers. The reserved name \"deterministic\" is built in and must not be declared here."
        }
      },
      "additionalProperties": false,
      "description": "Preferred grouping for who/what runs. Flattens to model/providers."
    },
    "policy": {
      "type": "object",
      "properties": {
        "permissionMode": {
          "type": "string",
          "enum": [
            "plan",
            "default",
            "accept_edits",
            "dont_ask",
            "bypass_permissions"
          ],
          "description": "Permission policy mode for runs started from the TUI."
        },
        "confidentialPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Opt-in read-confidentiality paths or globs whose contents a run must not read."
        },
        "write": {
          "type": "object",
          "properties": {
            "maxFiles": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991,
              "description": "Maximum distinct files a run may write."
            },
            "maxDiffLines": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991,
              "description": "Maximum changed diff lines per write."
            },
            "allowDeletions": {
              "type": "boolean",
              "description": "Whether in-place edits may remove lines."
            }
          },
          "additionalProperties": false,
          "description": "Workspace write guardrails. Merges conservatively across layers."
        },
        "sandbox": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["off", "warn", "enforce"],
              "description": "off disables OS sandboxing; warn uses it when available; enforce fails shell execution when sandboxing is unavailable."
            },
            "failIfUnavailable": {
              "type": "boolean",
              "description": "Fail closed when the platform sandbox runtime is unavailable."
            },
            "filesystem": {
              "type": "object",
              "properties": {
                "allowRead": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "allowWrite": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "denyRead": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "denyWrite": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "tmp": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "network": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["allow", "deny"]
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false,
          "description": "OS-level process sandbox for local command execution. Forced deny-write paths are always appended by the host."
        }
      },
      "additionalProperties": false,
      "description": "Preferred grouping for security boundaries. Flattens to permissionMode/confidentialPaths/write and shell.sandbox."
    },
    "run": {
      "type": "object",
      "properties": {
        "budget": {
          "type": "object",
          "properties": {
            "maxDurationMs": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "maxModelCalls": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "maxToolCalls": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "maxTokens": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "maxCostUsd": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "additionalProperties": false,
          "description": "Resource budget for the interactive main run. maxModelCalls is the tightest natural step bound."
        },
        "maxSteps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991,
          "description": "Explicit main-run step ceiling."
        },
        "traceLevel": {
          "type": "string",
          "enum": ["standard", "debug"],
          "description": "Default trace verbosity when an entrypoint does not pass one. CLI --trace-level overrides."
        },
        "approvals": {
          "type": "object",
          "properties": {
            "shellSafe": {
              "type": "boolean",
              "description": "Auto-approve commands the safety classifier rates safe."
            },
            "edits": {
              "type": "boolean",
              "description": "Auto-approve workspace edits."
            },
            "all": {
              "type": "boolean",
              "description": "Auto-approve everything the policy allows."
            },
            "cronMode": {
              "type": "string",
              "enum": [
                "plan",
                "default",
                "accept_edits",
                "dont_ask",
                "bypass_permissions"
              ],
              "description": "Default permission mode for unattended cron run/tick commands. CLI --permission-mode still overrides."
            }
          },
          "additionalProperties": false,
          "description": "Default approval auto-grants. CLI flags still override these values."
        }
      },
      "additionalProperties": false,
      "description": "Preferred grouping for run-shaping defaults. Flattens to runBudget/maxSteps/traceLevel/approvals."
    },
    "ui": {
      "type": "object",
      "properties": {
        "theme": {
          "type": "string",
          "enum": ["dark", "light", "mono"],
          "description": "Visual theme."
        },
        "mouse": {
          "type": "boolean",
          "description": "Enable mouse reporting."
        },
        "keybindings": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              {
                "type": "null"
              }
            ]
          },
          "description": "Override default key chords for named TUI actions."
        }
      },
      "additionalProperties": false,
      "description": "Preferred grouping for TUI-only preferences. Flattens to theme/mouse/keybindings."
    }
  },
  "additionalProperties": false
}
