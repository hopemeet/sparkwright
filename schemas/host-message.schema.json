{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkwright.dev/schemas/v0/host-message.schema.json",
  "x-sparkwrightProtocolVersion": "0.2",
  "title": "Sparkwright Host Message",
  "description": "Wire envelope for all messages exchanged between a Sparkwright host (server-runtime + transport) and a client (TUI, web SDK, etc). Newline-delimited JSON over stdio or one message per WebSocket frame. Every message is one of: request (client→host, expects response), response (host→client, paired with a request by id), or event (host→client, fire-and-forget). The host protocol is versioned via the top-level `protocolVersion` field on the handshake; v1.x is backwards compatible (fields may be added but never removed or repurposed). See docs/HOST_PROTOCOL.md.",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" },
    { "$ref": "#/$defs/Event" }
  ],
  "$defs": {
    "MessageId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier the sender chose. For requests, the response echoes the same id."
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp at which the sender produced the message."
    },
    "Request": {
      "type": "object",
      "required": ["envelope", "id", "kind", "timestamp", "payload"],
      "properties": {
        "envelope": { "const": "request" },
        "id": { "$ref": "#/$defs/MessageId" },
        "kind": {
          "type": "string",
          "enum": [
            "handshake",
            "run.start",
            "run.resume",
            "run.inject_message",
            "run.cancel",
            "approval.resolve",
            "session.list",
            "session.inspect",
            "session.fork",
            "session.compact",
            "task.list",
            "task.get",
            "task.output",
            "task.stop",
            "task.join",
            "task.promote",
            "workflow.list",
            "workflow.resume",
            "capability.inspect"
          ]
        },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "handshake" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/HandshakeRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "run.start" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/RunStartRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "run.resume" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/RunResumeRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "run.cancel" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/RunCancelRequestPayload" }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "run.inject_message" } }
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/RunInjectMessageRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "approval.resolve" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/ApprovalResolveRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "session.list" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/SessionListRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "session.inspect" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/SessionInspectRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "session.fork" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/SessionForkRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "session.compact" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/SessionCompactRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "task.list" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/TaskListRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "task.get" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/TaskGetRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "task.output" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/TaskOutputRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "task.stop" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/TaskStopRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "task.join" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/TaskJoinRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "task.promote" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/TaskPromoteRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "workflow.list" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/WorkflowListRequestPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "workflow.resume" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/WorkflowResumeRequestPayload" }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "capability.inspect" } }
          },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/CapabilityInspectRequestPayload" }
            }
          }
        }
      ]
    },
    "Response": {
      "type": "object",
      "required": ["envelope", "id", "ok", "timestamp"],
      "properties": {
        "envelope": { "const": "response" },
        "id": {
          "$ref": "#/$defs/MessageId",
          "description": "Echoes the originating request id."
        },
        "ok": { "type": "boolean" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "result": {
          "type": "object",
          "description": "Present when ok is true."
        },
        "error": {
          "$ref": "#/$defs/ProtocolError",
          "description": "Present when ok is false."
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "ok": { "const": true } },
            "required": ["ok"]
          },
          "then": {
            "required": ["result"],
            "properties": { "result": { "type": "object" } }
          }
        },
        {
          "if": {
            "properties": { "ok": { "const": false } },
            "required": ["ok"]
          },
          "then": {
            "required": ["error"],
            "properties": { "error": { "$ref": "#/$defs/ProtocolError" } }
          }
        }
      ]
    },
    "Event": {
      "type": "object",
      "required": ["envelope", "id", "kind", "timestamp", "payload"],
      "properties": {
        "envelope": { "const": "event" },
        "id": { "$ref": "#/$defs/MessageId" },
        "kind": {
          "type": "string",
          "enum": [
            "host.ready",
            "host.log",
            "run.event",
            "approval.requested",
            "run.completed",
            "run.failed"
          ]
        },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "host.ready" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/HostReadyEventPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "host.log" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/HostLogEventPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "run.event" } } },
          "then": {
            "properties": { "payload": { "$ref": "#/$defs/RunEventPayload" } }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "approval.requested" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/ApprovalRequestedEventPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "run.completed" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/RunCompletedEventPayload" }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "run.failed" } } },
          "then": {
            "properties": {
              "payload": { "$ref": "#/$defs/RunFailedEventPayload" }
            }
          }
        }
      ]
    },
    "ProtocolError": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "protocol_version_mismatch",
            "unknown_kind",
            "invalid_payload",
            "run_not_found",
            "approval_not_found",
            "session_not_found",
            "task_not_found",
            "internal_error"
          ]
        },
        "message": { "type": "string", "minLength": 1 },
        "details": { "type": "object" }
      },
      "additionalProperties": false
    },
    "RunFailureEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "category": { "type": "string" },
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "retryable": { "type": "boolean" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "HandshakeRequestPayload": {
      "type": "object",
      "required": ["protocolVersion", "client"],
      "properties": {
        "protocolVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$",
          "description": "Client's spoken protocol version (major.minor). Host rejects with protocol_version_mismatch when major differs from its own."
        },
        "client": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional list of optional features the client supports. Hosts ignore unknown entries."
        }
      },
      "additionalProperties": false
    },
    "RunStartRequestPayload": {
      "type": "object",
      "required": ["goal"],
      "properties": {
        "goal": { "type": "string", "minLength": 1 },
        "input": { "$ref": "#/$defs/RunInputPayload" },
        "sessionId": { "type": "string", "minLength": 1 },
        "targetPath": {
          "type": "string",
          "minLength": 1,
          "description": "Workspace-relative target path that the run should focus on when applicable."
        },
        "shouldWrite": {
          "type": "boolean",
          "description": "Whether this run is allowed to request workspace writes."
        },
        "model": { "type": "string", "minLength": 1 },
        "workflow": {
          "type": "string",
          "minLength": 1,
          "description": "Workflow asset name to instantiate for this run."
        },
        "accessMode": {
          "type": "string",
          "enum": ["read-only", "ask", "accept-edits", "bypass"],
          "description": "High-level run autonomy preset. When present, the host compiles it to permissionMode + shouldWrite and ignores a conflicting legacy permissionMode."
        },
        "backgroundTasks": {
          "type": "string",
          "enum": ["disabled", "foreground-only", "enabled"],
          "description": "Session-level foreground/background task policy."
        },
        "permissionMode": {
          "type": "string",
          "enum": [
            "plan",
            "default",
            "accept_edits",
            "dont_ask",
            "bypass_permissions"
          ]
        },
        "traceLevel": {
          "type": "string",
          "enum": ["standard", "debug"]
        },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "RunCancelRequestPayload": {
      "type": "object",
      "required": ["runId"],
      "properties": {
        "runId": { "type": "string", "minLength": 1 },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "RunResumeRequestPayload": {
      "type": "object",
      "required": ["runId"],
      "properties": {
        "runId": {
          "type": "string",
          "minLength": 1,
          "description": "Prior run to resume from a persisted checkpoint or reconstructed trace."
        },
        "sessionId": {
          "type": "string",
          "minLength": 1,
          "description": "Optional session scope used to disambiguate where the prior run lives."
        },
        "targetPath": {
          "type": "string",
          "minLength": 1,
          "description": "Workspace-relative target path that the resumed run should focus on when applicable."
        },
        "shouldWrite": {
          "type": "boolean",
          "description": "Whether the resumed run is allowed to request workspace writes."
        },
        "fromTrace": {
          "type": "boolean",
          "description": "Reconstruct a best-effort checkpoint from trace.jsonl when checkpoint.json is absent."
        },
        "force": {
          "type": "boolean",
          "description": "Allow resuming checkpoints that are terminal or otherwise normally refused."
        },
        "model": { "type": "string", "minLength": 1 },
        "accessMode": {
          "type": "string",
          "enum": ["read-only", "ask", "accept-edits", "bypass"],
          "description": "High-level run autonomy preset. When present, the host compiles it to permissionMode + shouldWrite and ignores a conflicting legacy permissionMode."
        },
        "backgroundTasks": {
          "type": "string",
          "enum": ["disabled", "foreground-only", "enabled"],
          "description": "Session-level foreground/background task policy."
        },
        "permissionMode": {
          "type": "string",
          "enum": [
            "plan",
            "default",
            "accept_edits",
            "dont_ask",
            "bypass_permissions"
          ]
        },
        "traceLevel": {
          "type": "string",
          "enum": ["standard", "debug"]
        },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "RunInjectMessageRequestPayload": {
      "type": "object",
      "required": ["runId", "content"],
      "properties": {
        "runId": { "type": "string", "minLength": 1 },
        "content": { "type": "string", "minLength": 1 },
        "input": { "$ref": "#/$defs/RunInputPayload" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "RunInputPayload": {
      "type": "object",
      "properties": {
        "parts": {
          "type": "array",
          "items": { "$ref": "#/$defs/RunInputPart" }
        },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "RunInputPart": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "text"],
          "properties": {
            "type": { "const": "text" },
            "text": { "type": "string" },
            "metadata": { "type": "object" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "type": "string", "enum": ["image", "file", "audio"] },
            "data": { "type": "string", "minLength": 1 },
            "uri": { "type": "string", "minLength": 1 },
            "mediaType": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "metadata": { "type": "object" }
          },
          "anyOf": [
            {
              "properties": { "data": { "type": "string", "minLength": 1 } },
              "required": ["data"]
            },
            {
              "properties": { "uri": { "type": "string", "minLength": 1 } },
              "required": ["uri"]
            }
          ],
          "additionalProperties": false
        }
      ]
    },
    "ApprovalResolveRequestPayload": {
      "type": "object",
      "required": ["approvalId", "decision"],
      "properties": {
        "approvalId": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["approved", "denied"] },
        "message": { "type": "string" },
        "autoApproved": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "SessionListRequestPayload": {
      "type": "object",
      "properties": {
        "limit": { "type": "integer", "minimum": 1, "maximum": 200 }
      },
      "additionalProperties": false
    },
    "SessionInspectRequestPayload": {
      "type": "object",
      "required": ["sessionId"],
      "properties": {
        "sessionId": { "type": "string", "minLength": 1 },
        "compaction": {
          "type": "boolean",
          "description": "Include a compact.json/session compaction event audit view without compacted summary content."
        }
      },
      "additionalProperties": false
    },
    "SessionForkRequestPayload": {
      "type": "object",
      "required": ["sourceSessionId"],
      "properties": {
        "sourceSessionId": { "type": "string", "minLength": 1 },
        "forkAtSequence": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "SessionCompactRequestPayload": {
      "type": "object",
      "required": ["sessionId"],
      "properties": {
        "sessionId": { "type": "string", "minLength": 1 },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "Optional caller label recorded in compaction diagnostics."
        },
        "llm": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "TaskStatus": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed", "cancelled"]
    },
    "WorkflowRunStatus": {
      "type": "string",
      "enum": ["running", "waiting", "completed", "failed", "cancelled"]
    },
    "TaskError": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "TaskRecordSnapshot": {
      "type": "object",
      "required": [
        "id",
        "parentRunId",
        "kind",
        "awaited",
        "status",
        "createdAt",
        "metadata"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "parentRunId": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "awaited": { "type": "boolean" },
        "status": { "$ref": "#/$defs/TaskStatus" },
        "createdAt": { "type": "string" },
        "startedAt": { "type": "string" },
        "lastOutputAt": { "type": "string" },
        "lastProgressAt": { "type": "string" },
        "lastHealthCheckAt": { "type": "string" },
        "outputChunks": { "type": "integer", "minimum": 0 },
        "outputBytes": { "type": "integer", "minimum": 0 },
        "completedAt": { "type": "string" },
        "result": {},
        "error": { "$ref": "#/$defs/TaskError" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "TaskOutputChunkSnapshot": {
      "type": "object",
      "required": ["taskId", "sequence", "timestamp", "channel", "data"],
      "properties": {
        "taskId": { "type": "string", "minLength": 1 },
        "sequence": { "type": "integer", "minimum": 0 },
        "timestamp": { "type": "string" },
        "channel": { "type": "string", "enum": ["stdout", "stderr", "event"] },
        "data": { "type": "string" }
      },
      "additionalProperties": false
    },
    "TaskListRequestPayload": {
      "type": "object",
      "properties": {
        "status": { "$ref": "#/$defs/TaskStatus" },
        "kind": { "type": "string", "minLength": 1 },
        "parentRunId": { "type": "string", "minLength": 1 },
        "limit": { "type": "integer", "minimum": 1, "maximum": 200 }
      },
      "additionalProperties": false
    },
    "TaskGetRequestPayload": {
      "type": "object",
      "required": ["taskId"],
      "properties": {
        "taskId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "TaskOutputRequestPayload": {
      "type": "object",
      "required": ["taskId"],
      "properties": {
        "taskId": { "type": "string", "minLength": 1 },
        "fromSequence": { "type": "integer", "minimum": 0 },
        "maxChunks": { "type": "integer", "minimum": 1, "maximum": 1000 }
      },
      "additionalProperties": false
    },
    "TaskStopRequestPayload": {
      "type": "object",
      "required": ["taskId"],
      "properties": {
        "taskId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "TaskJoinRequestPayload": {
      "type": "object",
      "required": ["taskId"],
      "properties": {
        "taskId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "TaskPromoteRequestPayload": {
      "type": "object",
      "required": ["taskId"],
      "properties": {
        "taskId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "WorkflowListRequestPayload": {
      "type": "object",
      "properties": {
        "sessionId": {
          "type": "string",
          "minLength": 1,
          "description": "Optional session scope used to limit workflow-run lookup."
        },
        "status": { "$ref": "#/$defs/WorkflowRunStatus" },
        "limit": { "type": "integer", "minimum": 1, "maximum": 200 }
      },
      "additionalProperties": false
    },
    "WorkflowResumeRequestPayload": {
      "type": "object",
      "required": ["workflowRunId"],
      "properties": {
        "workflowRunId": {
          "type": "string",
          "minLength": 1,
          "description": "Durable workflow instance id to resume."
        },
        "sessionId": {
          "type": "string",
          "minLength": 1,
          "description": "Optional session scope used to disambiguate where the workflow run lives."
        },
        "targetPath": {
          "type": "string",
          "minLength": 1,
          "description": "Workspace-relative target path that the resumed run should focus on when applicable."
        },
        "shouldWrite": {
          "type": "boolean",
          "description": "Whether the resumed run is allowed to request workspace writes."
        },
        "model": { "type": "string", "minLength": 1 },
        "accessMode": {
          "type": "string",
          "enum": ["read-only", "ask", "accept-edits", "bypass"],
          "description": "High-level run autonomy preset. When present, the host compiles it to permissionMode + shouldWrite and ignores a conflicting legacy permissionMode."
        },
        "backgroundTasks": {
          "type": "string",
          "enum": ["disabled", "foreground-only", "enabled"],
          "description": "Session-level foreground/background task policy."
        },
        "permissionMode": {
          "type": "string",
          "enum": [
            "plan",
            "default",
            "accept_edits",
            "dont_ask",
            "bypass_permissions"
          ]
        },
        "traceLevel": {
          "type": "string",
          "enum": ["standard", "debug"]
        },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "CapabilityInspectRequestPayload": {
      "type": "object",
      "properties": {
        "sessionId": {
          "type": "string",
          "minLength": 1,
          "description": "Reserved for future scoped inspection. Omit to inspect this connection's current host capability state."
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "description": "Model reference in provider/model form, or the reserved deterministic model."
        }
      },
      "additionalProperties": false
    },
    "CapabilitySnapshot": {
      "type": "object",
      "required": ["tools", "skills", "mcp", "agents"],
      "properties": {
        "model": { "$ref": "#/$defs/CapabilityModelSummary" },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/$defs/CapabilityToolSummary" }
        },
        "skills": {
          "type": "object",
          "required": ["indexed", "loaded"],
          "properties": {
            "indexed": {
              "type": "array",
              "items": { "$ref": "#/$defs/CapabilitySkillSummary" }
            },
            "loaded": {
              "type": "array",
              "items": { "$ref": "#/$defs/CapabilitySkillSummary" }
            },
            "inlineShell": {
              "$ref": "#/$defs/CapabilitySkillInlineShellSummary"
            }
          },
          "additionalProperties": false
        },
        "mcp": {
          "type": "object",
          "required": ["statuses"],
          "properties": {
            "statuses": {
              "type": "array",
              "items": { "$ref": "#/$defs/CapabilityMcpStatus" }
            }
          },
          "additionalProperties": false
        },
        "agents": {
          "type": "object",
          "required": ["profiles", "delegateTools"],
          "properties": {
            "profiles": {
              "type": "array",
              "items": { "$ref": "#/$defs/CapabilityAgentSummary" }
            },
            "delegateTools": {
              "type": "array",
              "items": { "$ref": "#/$defs/CapabilityDelegateToolSummary" }
            }
          },
          "additionalProperties": false
        },
        "shell": {
          "type": "object",
          "properties": {
            "foregroundTimeoutMs": { "type": "integer", "minimum": 1 },
            "promotionAvailable": { "type": "boolean" },
            "sandbox": { "$ref": "#/$defs/CapabilityShellSandboxSummary" }
          },
          "additionalProperties": false
        },
        "rules": {
          "type": "object",
          "required": ["workflow"],
          "properties": {
            "workflow": {
              "type": "array",
              "items": { "$ref": "#/$defs/CapabilityWorkflowRuleSummary" }
            },
            "events": {
              "type": "array",
              "items": { "$ref": "#/$defs/CapabilityEventRuleSummary" }
            }
          },
          "additionalProperties": false
        },
        "workflows": {
          "type": "object",
          "required": ["assets"],
          "properties": {
            "assets": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/CapabilityWorkflowAssetSummary"
              }
            },
            "errors": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/CapabilityWorkflowAssetErrorSummary"
              }
            }
          },
          "additionalProperties": false
        },
        "automation": { "$ref": "#/$defs/CapabilityAutomationSummary" }
      },
      "additionalProperties": false
    },
    "CapabilityWorkflowAssetSummary": {
      "type": "object",
      "required": [
        "assetName",
        "sourcePath",
        "layer",
        "contentHash",
        "nodeCount"
      ],
      "properties": {
        "assetName": { "type": "string", "minLength": 1 },
        "sourcePath": { "type": "string", "minLength": 1 },
        "layer": { "type": "string", "enum": ["builtin", "user", "project"] },
        "contentHash": { "type": "string", "minLength": 1 },
        "version": { "type": "string" },
        "description": { "type": "string" },
        "nodeCount": { "type": "integer", "minimum": 0 },
        "configPath": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "CapabilityWorkflowAssetErrorSummary": {
      "type": "object",
      "required": ["sourcePath", "layer", "message"],
      "properties": {
        "sourcePath": { "type": "string", "minLength": 1 },
        "layer": { "type": "string", "enum": ["builtin", "user", "project"] },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CapabilityWorkflowRuleSummary": {
      "type": "object",
      "required": [
        "name",
        "source",
        "lifecycle",
        "matcher",
        "action",
        "blockingPotential",
        "enabled",
        "active",
        "status"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "source": {
          "type": "string",
          "enum": ["config", "verification", "builtin"]
        },
        "lifecycle": { "type": "string", "minLength": 1 },
        "matcher": { "type": "string" },
        "action": { "type": "string" },
        "blockingPotential": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "active": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": ["active", "available", "inactive", "disabled"]
        },
        "description": { "type": "string" },
        "disableHint": { "type": "string" },
        "configurationHint": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CapabilityEventRuleSummary": {
      "type": "object",
      "required": [
        "name",
        "source",
        "trigger",
        "matcher",
        "action",
        "blockingPotential",
        "enabled",
        "active",
        "status"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "source": {
          "type": "string",
          "enum": ["config", "verification", "builtin"]
        },
        "trigger": { "type": "string", "minLength": 1 },
        "matcher": { "type": "string" },
        "action": { "type": "string" },
        "blockingPotential": { "const": false },
        "enabled": { "type": "boolean" },
        "active": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": ["active", "available", "inactive", "disabled"]
        },
        "description": { "type": "string" },
        "disableHint": { "type": "string" },
        "configurationHint": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CapabilityModelSummary": {
      "type": "object",
      "required": [
        "modelRef",
        "providerKey",
        "modelId",
        "adapterId",
        "pricing"
      ],
      "properties": {
        "modelRef": { "type": "string", "minLength": 1 },
        "providerKey": { "type": "string", "minLength": 1 },
        "modelId": { "type": "string", "minLength": 1 },
        "adapterId": { "type": "string", "minLength": 1 },
        "pricing": { "$ref": "#/$defs/CapabilityModelPricingSummary" }
      },
      "additionalProperties": false
    },
    "CapabilityModelPricingSummary": {
      "type": "object",
      "required": ["source", "costStatus"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["configured", "builtin", "unavailable", "not_applicable"]
        },
        "costStatus": {
          "type": "string",
          "enum": ["estimated", "unavailable", "not_applicable"]
        },
        "costUnavailableReason": { "type": "string" },
        "warning": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CapabilityShellSandboxSummary": {
      "type": "object",
      "required": [
        "mode",
        "failIfUnavailable",
        "runtimeId",
        "platform",
        "available",
        "networkMode",
        "filesystemIsolation"
      ],
      "properties": {
        "mode": { "type": "string" },
        "failIfUnavailable": { "type": "boolean" },
        "runtimeId": { "type": "string" },
        "platform": { "type": "string" },
        "available": { "type": "boolean" },
        "networkMode": { "type": "string" },
        "filesystemIsolation": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CapabilityToolSummary": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "canonicalName": { "type": "string", "minLength": 1 },
        "legacyNames": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "defaultExposureTier": {
          "type": "string",
          "enum": ["public", "advanced", "infrastructure", "internal", "legacy"]
        },
        "source": { "type": "string" },
        "origin": { "type": "string" },
        "risk": { "type": "string" },
        "governance": { "type": "object", "additionalProperties": true },
        "effectiveLoading": {
          "type": "string",
          "enum": ["eager", "deferred"]
        },
        "deferred": { "type": "boolean" },
        "disabled": { "type": "boolean" },
        "relatedTools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "requiresTool": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "CapabilitySkillSummary": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "sourcePath": { "type": "string" },
        "contentHash": { "type": "string" },
        "version": { "type": "string" },
        "selectionReason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CapabilitySkillInlineShellSummary": {
      "type": "object",
      "required": ["enabled", "sandboxMode", "writePolicy", "failClosed"],
      "properties": {
        "enabled": { "type": "boolean" },
        "timeoutMs": { "type": "number" },
        "maxOutputChars": { "type": "number" },
        "sandboxMode": { "type": "string" },
        "writePolicy": {
          "type": "string",
          "enum": ["disabled", "no-write"]
        },
        "failClosed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "CapabilityMcpStatus": {
      "type": "object",
      "required": ["serverName", "status", "toolNames"],
      "properties": {
        "serverName": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "toolNames": { "type": "array", "items": { "type": "string" } },
        "errorCode": { "type": "string" },
        "errorPhase": { "type": "string" },
        "errorMessage": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CapabilityAgentSummary": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "mode": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CapabilityDelegateToolSummary": {
      "type": "object",
      "required": [
        "toolName",
        "profileId",
        "protocol",
        "risk",
        "requiresApproval",
        "forbidNesting",
        "sideEffects",
        "workspaceAccess",
        "shellAccess",
        "processSpawn"
      ],
      "properties": {
        "toolName": { "type": "string", "minLength": 1 },
        "profileId": { "type": "string", "minLength": 1 },
        "profileName": { "type": "string" },
        "protocol": {
          "type": "string",
          "enum": ["acp", "external_command", "in_process"]
        },
        "model": { "type": "string", "minLength": 1 },
        "risk": {
          "type": "string",
          "enum": ["safe", "risky", "denied"]
        },
        "requiresApproval": { "type": "boolean" },
        "approvalRequiredUnderCurrentRun": { "type": "boolean" },
        "approvalReasons": { "type": "array", "items": { "type": "string" } },
        "approvalRunOptions": {
          "type": "object",
          "properties": {
            "shouldWrite": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "forbidNesting": { "type": "boolean" },
        "sideEffects": { "type": "array", "items": { "type": "string" } },
        "workspaceAccess": {
          "type": "string",
          "enum": ["none", "read_write"]
        },
        "shellAccess": { "type": "boolean" },
        "processSpawn": { "type": "boolean" },
        "gatedByRunWrite": { "type": "boolean" },
        "routing": { "$ref": "#/$defs/CapabilityDelegateRoutingSummary" },
        "command": { "type": "string", "minLength": 1 },
        "args": { "type": "array", "items": { "type": "string" } },
        "timeoutMs": { "type": "number" },
        "outputLimits": {
          "type": "object",
          "properties": {
            "stdoutBytes": { "type": "number" },
            "stderrBytes": { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "CapabilityDelegateRoutingSummary": {
      "type": "object",
      "required": ["keywords"],
      "properties": {
        "keywords": { "type": "array", "items": { "type": "string" } },
        "mode": { "const": "sort" },
        "relevance": {
          "type": "string",
          "enum": ["relevant", "low"]
        },
        "score": { "type": "number" },
        "matchedKeywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CapabilityAutomationSummary": {
      "type": "object",
      "required": ["cron", "tasks"],
      "properties": {
        "cron": {
          "type": "object",
          "required": ["rootDir", "jobs", "total"],
          "properties": {
            "rootDir": { "type": "string" },
            "jobs": {
              "type": "array",
              "items": { "$ref": "#/$defs/CapabilityCronJobSummary" }
            },
            "total": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "tasks": {
          "type": "object",
          "required": ["rootDir", "tasks", "total"],
          "properties": {
            "rootDir": { "type": "string" },
            "tasks": {
              "type": "array",
              "items": { "$ref": "#/$defs/CapabilityTaskSummary" }
            },
            "total": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "CapabilityCronJobSummary": {
      "type": "object",
      "required": [
        "id",
        "name",
        "enabled",
        "state",
        "schedule",
        "nextRunAt",
        "lastRunAt",
        "lastStatus",
        "lastError"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "state": { "type": "string" },
        "schedule": { "type": "string" },
        "nextRunAt": { "type": ["string", "null"] },
        "lastRunAt": { "type": ["string", "null"] },
        "lastStatus": { "type": ["string", "null"] },
        "lastError": { "type": ["string", "null"] },
        "lastTracePath": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "CapabilityTaskSummary": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "status",
        "awaited",
        "parentRunId",
        "createdAt"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string" },
        "status": { "type": "string" },
        "title": { "type": "string" },
        "awaited": { "type": "boolean" },
        "parentRunId": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string" },
        "completedAt": { "type": "string" },
        "outputChunks": { "type": "number" },
        "lastOutputAt": { "type": "string" },
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "HostReadyEventPayload": {
      "type": "object",
      "required": ["protocolVersion", "host"],
      "properties": {
        "protocolVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$",
          "description": "Host's spoken protocol version. Always sent immediately after a successful handshake."
        },
        "host": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "HostLogEventPayload": {
      "type": "object",
      "required": ["level", "line"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["stdout", "stderr", "info", "warn", "error"]
        },
        "line": { "type": "string" },
        "source": {
          "type": "string",
          "description": "Optional logical source (e.g. 'host', 'tool:bash', 'model')."
        }
      },
      "additionalProperties": false
    },
    "RunEventPayload": {
      "type": "object",
      "required": ["runId", "event"],
      "properties": {
        "runId": { "type": "string", "minLength": 1 },
        "event": {
          "type": "object",
          "description": "A SparkwrightEvent as defined by schemas/event.schema.json. Passed through verbatim; clients can re-validate against that schema if they need to."
        }
      },
      "additionalProperties": false
    },
    "ApprovalRequestedEventPayload": {
      "type": "object",
      "required": ["runId", "approvalId", "action", "summary"],
      "properties": {
        "runId": { "type": "string", "minLength": 1 },
        "approvalId": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "details": { "type": "object" }
      },
      "additionalProperties": false
    },
    "RunCompletedEventPayload": {
      "type": "object",
      "required": ["runId", "state"],
      "properties": {
        "runId": { "type": "string", "minLength": 1 },
        "state": { "type": "string" },
        "stopReason": { "type": "string" },
        "message": { "type": "string" },
        "outcome": { "type": "object" },
        "failure": { "$ref": "#/$defs/RunFailureEnvelope" },
        "todoHandoff": {
          "type": "object",
          "required": ["reason", "message"],
          "properties": {
            "reason": { "type": "string", "minLength": 1 },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "RunFailedEventPayload": {
      "type": "object",
      "required": ["runId", "failure", "error"],
      "properties": {
        "runId": { "type": "string", "minLength": 1 },
        "failure": { "$ref": "#/$defs/RunFailureEnvelope" },
        "error": { "$ref": "#/$defs/ProtocolError" }
      },
      "additionalProperties": false
    }
  }
}
