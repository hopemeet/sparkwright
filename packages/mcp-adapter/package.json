{
  "name": "@sparkwright/mcp-adapter",
  "version": "0.1.0",
  "description": "MCP capability ingress helpers for Sparkwright tools.",
  "license": "Apache-2.0",
  "author": "hopemeet <https://x.com/hopemeet_ai>",
  "homepage": "https://github.com/hopemeet/sparkwright#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopemeet/sparkwright.git",
    "directory": "packages/mcp-adapter"
  },
  "bugs": {
    "url": "https://github.com/hopemeet/sparkwright/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/stamp-workspace-build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sparkwright/core": "0.1.0",
    "@sparkwright/shell-sandbox": "0.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "sideEffects": false,
  "keywords": [
    "agents",
    "mcp",
    "tools",
    "runtime"
  ]
}
