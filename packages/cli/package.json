{
  "name": "@sparkwright/cli",
  "version": "0.1.0",
  "description": "Local CLI for running Sparkwright agent harness golden paths.",
  "license": "Apache-2.0",
  "author": "hopemeet <https://x.com/hopemeet_ai>",
  "homepage": "https://github.com/hopemeet/sparkwright#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopemeet/sparkwright.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/hopemeet/sparkwright/issues"
  },
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "sparkwright": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/chmod-bin.mjs dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "@sparkwright/acp-adapter": "0.1.0",
    "@sparkwright/agent-runtime": "0.1.0",
    "@sparkwright/core": "0.1.0",
    "@sparkwright/cron": "0.1.0",
    "@sparkwright/host": "0.1.0",
    "@sparkwright/mcp-adapter": "0.1.0",
    "@sparkwright/project-context": "0.1.0",
    "@sparkwright/provider-ai-sdk": "0.1.0",
    "@sparkwright/provider-registry": "0.1.0",
    "@sparkwright/sdk-node": "0.1.0",
    "@sparkwright/shell-sandbox": "0.1.0",
    "@sparkwright/skills": "0.1.0",
    "@sparkwright/tui": "0.1.0",
    "undici": "^7.26.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "keywords": [
    "agents",
    "cli",
    "runtime",
    "trace",
    "approval"
  ]
}
