{
  "name": "@sparkwright/protocol",
  "version": "0.1.0",
  "description": "Shared wire-protocol types for the Sparkwright host. See docs/HOST_PROTOCOL.md.",
  "license": "Apache-2.0",
  "author": "hopemeet <https://x.com/hopemeet_ai>",
  "homepage": "https://github.com/hopemeet/sparkwright#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopemeet/sparkwright.git",
    "directory": "packages/protocol"
  },
  "bugs": {
    "url": "https://github.com/hopemeet/sparkwright/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/stamp-workspace-build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "keywords": [
    "sparkwright",
    "protocol",
    "types"
  ]
}
