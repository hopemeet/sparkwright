{
  "name": "@sparkwright/sdk-core",
  "version": "0.1.0",
  "description": "Transport-agnostic Sparkwright host client (Client class). Used by @sparkwright/sdk-node and @sparkwright/sdk-browser. See docs/HOST_PROTOCOL.md.",
  "license": "Apache-2.0",
  "author": "hopemeet <https://x.com/hopemeet_ai>",
  "homepage": "https://github.com/hopemeet/sparkwright#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopemeet/sparkwright.git",
    "directory": "packages/sdk-core"
  },
  "bugs": {
    "url": "https://github.com/hopemeet/sparkwright/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sparkwright/protocol": "0.1.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "keywords": [
    "sparkwright",
    "sdk",
    "client",
    "isomorphic"
  ],
  "sideEffects": false
}
