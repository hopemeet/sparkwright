{
  "name": "@sparkwright/sdk-node",
  "version": "0.1.0",
  "description": "Node client SDK for the Sparkwright host. Spawn a local host or attach to a running one. See docs/HOST_PROTOCOL.md.",
  "license": "Apache-2.0",
  "author": "hopemeet <https://x.com/hopemeet_ai>",
  "homepage": "https://github.com/hopemeet/sparkwright#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopemeet/sparkwright.git",
    "directory": "packages/sdk-node"
  },
  "bugs": {
    "url": "https://github.com/hopemeet/sparkwright/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sparkwright/protocol": "0.1.0",
    "@sparkwright/sdk-core": "0.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@sparkwright/host": "0.1.0",
    "@types/ws": "^8.5.13",
    "vitest": "^3.2.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "keywords": [
    "sparkwright",
    "sdk",
    "client"
  ]
}
