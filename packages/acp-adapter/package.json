    "@sparkwright/protocol": "0.1.0",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "sideEffects": false,
  "keywords": [
    "agents",
    "acp",
    "adapter",
    "runtime"
