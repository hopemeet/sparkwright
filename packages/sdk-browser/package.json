{
  "name": "@sparkwright/sdk-browser",
  "version": "0.1.0",
  "description": "Browser client SDK for the Sparkwright host. Pure ESM, no Node deps; uses native WebSocket. See docs/HOST_PROTOCOL.md.",
  "license": "Apache-2.0",
  "author": "hopemeet <https://x.com/hopemeet_ai>",
  "homepage": "https://github.com/hopemeet/sparkwright#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopemeet/sparkwright.git",
    "directory": "packages/sdk-browser"
  },
  "bugs": {
    "url": "https://github.com/hopemeet/sparkwright/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/stamp-workspace-build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sparkwright/sdk-core": "0.1.0"
  },
  "devDependencies": {
    "vitest": "^3.2.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "keywords": [
    "sparkwright",
    "sdk",
    "client",
    "browser",
    "websocket"
  ],
  "sideEffects": false,
  "browser": {
    "node:child_process": false,
    "node:readline": false,
    "node:fs": false
  }
}
