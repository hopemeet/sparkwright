node_modules/
dist/
coverage/
.DS_Store
npm-debug.log*
.claude/

# TypeScript incremental build cache (tsc -b / "incremental": true)
*.tsbuildinfo

__pycache__/
*.pyc

# Secrets / local env
.env
.env.*
!.env.example

# Editor / IDE
.vscode/
.idea/
.cursor/
*.swp

# Internal docs and dashboards (local-only, not for public repo)
docs/_internal/
README.internal.md

# SparkWright local runtime state. The committed project config surface
# (.sparkwright/config.json and the command/ + agents/ convention dirs) is
# intentionally NOT ignored so it travels with the repo; only runtime state is.
# `**/` so nested workspaces (e.g. examples/*/.sparkwright) are covered too.
**/.sparkwright/sessions/
**/.sparkwright/runs/
**/.sparkwright/test-iface-runs/
**/.sparkwright/tui-history.jsonl
**/.sparkwright/tui-stash.json

# Personal, local-only dev notes (never committed; survives switching tools)
*.local.md
